# Copy this file to .env.local and fill in the values.
# Never commit .env.local. Never paste real keys into chat.

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, bypasses RLS. Used by admin / cron tasks.
# Keep this OUT of any NEXT_PUBLIC_* variable.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-key-here

# ---- Site URL ----
# Used for auth email redirects and OG / metadata. Production: https://nurlan.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- PostHog ----
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Upstash Redis (rate limiting) ----
# Create a Redis database at https://console.upstash.com/redis
# Copy "REST URL" and "REST Token" from the database overview.
# Required in production; missing in development logs a warning and bypasses
# rate limiting (the rate-limit module decides this — see src/lib/rate-limit.ts).
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
